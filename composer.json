{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "juniyasyos/sp-ikp",
    "type": "project",
    "description": "A comprehensive Patient Safety Incident Reporting System designed to support incident management, investigation, corrective actions, and healthcare quality improvement.",
    "keywords": [
        "patient-safety",
        "incident-reporting",
        "incident-management",
        "risk-management",
        "healthcare",
        "hospital",
        "quality-improvement",
        "quality-management",
        "patient-safety-incident",
        "healthcare-compliance",
        "laravel",
        "filament"
    ],
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "bezhansalleh/filament-shield": "^4.1",
        "filament/filament": "^4.0",
        "guava/filament-modal-relation-managers": "^2.0",
        "juniyasyos/nexaid-client": "v1.2.11",
        "juniyasyos/filament-media-manager": "v1.4.1",
        "laravel/framework": "^12.0",
        "laravel/tinker": "^2.10.1",
        "league/flysystem-aws-s3-v3": "^3.25.1",
        "leandrocfe/filament-apex-charts": "^5.1",
        "livewire/livewire": "^3.0",
        "spykapps/theme-edinburgh": "^1.0",
        "stechstudio/filament-impersonate": "^5.1"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^4.2",
        "fakerphp/faker": "^1.23",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.24",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^4.1",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install && composer update",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force"
        ],
        "dev-setup": [
            "Composer\\Config::disableProcessTimeout",
            "rm -rf ./storage/debugbar/*.json",
            "@php artisan migrate:fresh",
            "@php artisan db:seed --class=DatabaseSeeder"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185\" \"php artisan serve --port=8200\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" --names=server,queue,logs --kill-others"
        ],
        "iam": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve --port=8200\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" --names=server,queue,logs --kill-others"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ],
        "wipe-db": [
            "mysql -h 127.0.0.1 -u juni -ppassword -e \"DROP DATABASE IF EXISTS ikp; CREATE DATABASE ikp CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;\"",
            "mysql -h 127.0.0.1 -u juni -ppassword --max_allowed_packet=512M --net_buffer_length=16384 ikp < ./database/schema/ikp_db_new.sql"
        ],
        "safe-migrate": [
            "@composer run wipe-db",
            "@php artisan tinker --execute=\"(require 'database/migrations/0001_01_01_000001_create_cache_table.php')->up();\"",
            "mv database/migrations/2026_06_30_085238_drop_investigation_columns_from_laporan_insidens.php database/migrations/2026_06_30_085238_drop_investigation_columns_from_laporan_insidens.php.bak || true",
            "@php artisan migrate --force",
            "@php artisan app:migrate-legacy-laporan-insiden-data",
            "mv database/migrations/2026_06_30_085238_drop_investigation_columns_from_laporan_insidens.php.bak database/migrations/2026_06_30_085238_drop_investigation_columns_from_laporan_insidens.php || true"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "wikimedia/composer-merge-plugin": true
        },
        "audit": {
            "ignore": [
                "PKSA-y2cr-5h3j-g3ys"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}